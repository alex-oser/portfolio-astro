---
// Static card wrapper, ported from the MUI <Card> (react/CardLayout.tsx).
// Replicates MUI's dark-mode elevation-1 Paper: #121212 base with a 5% white
// overlay, 4px radius, and the three-layer elevation shadow.
interface Props {
  class?: string;
  /** Stack children in a column with space-between (used by ProjectCard so its
      action row sits at the bottom of the card). */
  column?: boolean;
}

const { class: className, column = false } = Astro.props;
---

<div class:list={['card', { column }, className]}><slot /></div>

<style>
  .card {
    width: 100%;
    height: 200px;
    cursor: pointer;
    border-radius: 4px;
    color: white;
    background-image: linear-gradient(rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.05));
    background-color: #121212;
    box-shadow:
      0px 2px 1px -1px rgba(0, 0, 0, 0.2),
      0px 1px 1px 0px rgba(0, 0, 0, 0.14),
      0px 1px 3px 0px rgba(0, 0, 0, 0.12);
  }
  .card.column {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
</style>
