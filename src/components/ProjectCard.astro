---
// Project card, ported from react/ProjectCard.tsx. The card body links to the
// project page; the action row has external GitHub / live-site links (inline
// SVGs replace the old @mui/icons-material icons, tinted with --primary).
import CardLayout from './CardLayout.astro';
import ProjectStatus from './ProjectStatus.astro';
import { toSlug, type ProjectMeta } from './types';

interface Props {
  frontmatter: ProjectMeta;
}

const { frontmatter } = Astro.props;
const { title, status, caption, link, repo } = frontmatter;
const path = `/projects/${toSlug(title)}`;
---

<CardLayout column>
  <a href={path} class="card-link">
    <div class="card-content">
      <div class="title-row">
        <h6 class="card-title"><strong>{title}</strong></h6>
        <ProjectStatus status={status} />
      </div>
      <p class="caption">{caption}</p>
    </div>
  </a>
  <div class="card-actions">
    {
      repo && (
        <a target="_blank" rel="noopener" href={repo} aria-label="GitHub repo" class="icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </a>
      )
    }
    {
      link && (
        <a target="_blank" rel="noopener" href={link} aria-label="Live site link" class="icon">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor" aria-hidden="true">
            <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm6.93 6h-2.95c-.32-1.25-.78-2.45-1.38-3.56 1.84.63 3.37 1.91 4.33 3.56zM12 4.04c.83 1.2 1.48 2.53 1.91 3.96h-3.82c.43-1.43 1.08-2.76 1.91-3.96zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.38c-.08.66-.14 1.32-.14 2 0 .68.06 1.34.14 2H4.26zm.82 2h2.95c.32 1.25.78 2.45 1.38 3.56-1.84-.63-3.37-1.9-4.33-3.56zm2.95-8H5.08c.96-1.66 2.49-2.93 4.33-3.56C8.81 5.55 8.35 6.75 8.03 8zM12 19.96c-.83-1.2-1.48-2.53-1.91-3.96h3.82c-.43 1.43-1.08 2.76-1.91 3.96zM14.34 14H9.66c-.09-.66-.16-1.32-.16-2 0-.68.07-1.35.16-2h4.68c.09.65.16 1.32.16 2 0 .68-.07 1.34-.16 2zm.25 5.56c.6-1.11 1.06-2.31 1.38-3.56h2.95c-.96 1.65-2.49 2.93-4.33 3.56zM16.36 14c.08-.66.14-1.32.14-2 0-.68-.06-1.34-.14-2h3.38c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.38z" />
          </svg>
        </a>
      )
    }
  </div>
</CardLayout>

<style>
  .card-link {
    text-decoration: none;
    /* Grow to fill the card so the action row is pushed to the bottom. */
    flex: 1;
    color: white;
  }
  .card-content {
    padding: 16px 16px 24px;
  }
  .title-row {
    display: flex;
  }
  .card-title {
    font-size: 20px;
    font-weight: 500;
    line-height: 1.6;
    margin: 0;
    color: white;
  }
  .caption {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    color: white;
  }
  .card-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px;
  }
  .icon {
    display: flex;
    align-items: center;
    color: var(--primary);
  }
</style>
