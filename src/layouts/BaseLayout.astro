---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead />
  </head>
  <body>
    <!-- Static header; same-page smooth scroll handled by CSS scroll-behavior. -->
    <Header />
    <div class="layout">
      <main>
        <slot />
      </main>
      <footer>
        &copy; {year}, Built with <a href="https://astro.build">Astro</a>
      </footer>
    </div>
    <style>
      .layout {
        margin: auto;
        max-width: 1400px;
        padding: 24px;
      }
      @media (min-width: 900px) {
        .layout {
          padding: 0 80px;
        }
      }
      footer {
        margin-top: 2rem;
        padding-bottom: 2rem;
        color: var(--text-dim);
      }
    </style>
  </body>
</html>
